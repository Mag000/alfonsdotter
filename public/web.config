<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <httpErrors errorMode="Detailed" />
        <staticContent>
            <mimeMap fileExtension=".webp" mimeType="image/webp" />
        </staticContent>
<rewrite>
    <rules>
        <rule name="Demo Routes" stopProcessing="true">
        <!-- url matched relative to this folder, so no "demo/" prefix -->
        <match url=".*" />
        <conditions logicalGrouping="MatchAll">
            <!-- skip real files -->
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <!-- skip static asset folders and API (REQUEST_URI is always full path) -->
            <add input="{REQUEST_URI}" pattern="^/demo/(assets|img|api)(/|$)" negate="true" />
        </conditions>
        <action type="Rewrite" url="/demo/index.html" />
        </rule>
    </rules>
</rewrite>
        <defaultDocument>
            <files>
                <clear />
                <add value="index.html" />
                <add value="Default.htm" />
                <add value="Default.asp" />
                <add value="index.htm" />
                <add value="iisstart.htm" />
            </files>
        </defaultDocument>
</system.webServer>
</configuration>

